FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y ffmpeg && rm -rf /var/lib/apt/lists/*

COPY pyproject.toml .
RUN pip install livekit-agents livekit-plugins-google \
    livekit-plugins-silero livekit-plugins-turn-detector \
    livekit-plugins-noise-cancellation python-dotenv

COPY . .

# pre-download turn detector model at build time
RUN python gemini_voice_agent.py download-files

CMD ["python", "gemini_voice_agent.py", "start"]